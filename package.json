{
  "name": "ts-orm-benchmark",
  "version": "0.1.0",
  "description": "⚡ TypeScript ORM & query builder SQL generation benchmark — UQL vs Sequelize vs TypeORM vs MikroORM vs Drizzle vs Knex vs Kysely",
  "type": "module",
  "scripts": {
    "bench": "npx vitest bench --run 2>&1 | tee /dev/stderr | bun scripts/update-results.ts",
    "ts": "tsc --noEmit"
  },
  "keywords": [
    "orm",
    "benchmark",
    "typescript",
    "typeorm",
    "drizzle",
    "mikro-orm",
    "sequelize",
    "uql",
    "performance",
    "sql-generation"
  ],
  "author": "Roger Padilla <sonemonu@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@mikro-orm/better-sqlite": "^6.6.9",
    "@mikro-orm/core": "^6.6.9",
    "@mikro-orm/knex": "^6.6.9",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.10",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "knex": "^3.1.0",
    "kysely": "^0.28.11",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "uql-orm": "^0.2.3",
    "vitest": "^4.0.18"
  }
}
